# ==========================================
# SiloGenius Engine - Environment Variables
# ==========================================

# --- AI PROVIDERS ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_key_here"

# Model selection (e.g., 'arcee-ai/trinity-large-preview:free' or 'anthropic/claude-3-haiku')
OPENROUTER_MODEL="your_selected_model_here"

# Get your key at: https://aistudio.google.com/apikey (For AI Image Generation)
GOOGLE_API_KEY="your_google_ai_studio_key_here"

# Model selection (e.g., 'gemini-2.0-flash-exp-image-generation')
GOOGLE_IMAGE_MODEL="your_selected_image_model_here"

# --- WORDPRESS PUBLISHING ---
# The base URL of your WordPress site (e.g., http://localhost/wordpress or https://myblog.com)
WP_URL="https://your-wordpress-site.com"

# An Editor or Administrator username
WP_USERNAME="admin"

# Generate this in WordPress -> Users -> Profile -> Application Passwords
WP_APP_PASSWORD="your_application_password_here"
